<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <!-- Top Toolbar Area -->
    <LinearLayout
        android:id="@+id/toolbar_drive_viewer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="?android:attr/colorPrimary"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/back_button_drive_viewer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Go Back"
            android:tint="?android:attr/textColorPrimaryInverse" />

        <TextView
            android:id="@+id/title_drive_viewer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Google Drive"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimaryInverse"
            android:layout_marginStart="16dp"
            android:maxLines="1"
            android:ellipsize="end" />
            
    </LinearLayout>

    <!-- Main Content Area: RecyclerView for Files/Folders -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/drive_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar_drive_viewer"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:scrollbars="vertical" />

    <!-- Loading State: Indeterminate Progress Bar -->
    <ProgressBar
        android:id="@+id/drive_progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- Empty State: Text shown when a folder has no files -->
    <TextView
        android:id="@+id/empty_view_drive"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="This folder is empty."
        android:textSize="16sp"
        android:textColor="?android:attr/textColorSecondary"
        android:visibility="gone" />

</RelativeLayout>