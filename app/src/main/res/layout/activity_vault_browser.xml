<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f1724">

    <!-- Header / Toolbar -->
    <RelativeLayout
        android:id="@+id/header_vault_browser"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#0b1220"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/back_button_vault"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#e6eef8" />

        <TextView
            android:id="@+id/title_text_vault"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Secure Vault"
            android:textColor="#e6eef8"
            android:textSize="20sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_vault_browser">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/vault_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp" />

        <TextView
            android:id="@+id/empty_vault_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Your Secure Vault is Empty"
            android:textColor="#9aa7bd"
            android:textSize="16sp"
            android:visibility="gone" />

    </FrameLayout>

</RelativeLayout>