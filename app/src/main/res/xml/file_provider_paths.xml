<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Path for the secure, temporary playback cache.
         This fixes the "Failed to find configured root" error by allowing 
         the sharing of files from the app's internal cache directory. -->
    <cache-path
        name="secure_playback_cache"
        path="secure_cache/" />

    <!-- Path for general app files access -->
    <files-path
        name="internal_files"
        path="." />

    <!-- Path for general external storage access.
         This preserves your existing ability to share files from 
         public directories and the root of external storage. -->
    <external-path
        name="external_files"
        path="." />

</paths>